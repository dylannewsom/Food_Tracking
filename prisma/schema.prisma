// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// The Master Dictionary (The "Base Truth" of an item)
model FoodItem {
  id              String         @id @default(uuid())
  name            String         @unique
  barcode         String?        @unique // for when we add the scanner
  baseServingSize Float?
  baseServingUnit String?        // e.g. "g", "oz", "cup"
  baseCalories    Float
  baseProtein     Float
  baseFat         Float  
  baseCarbs       Float  
  baseCaffeine    Float 
  price           Float?        // for when we add the price tracking
  rating          Float?        // for when we add the rating system
  
  // A relationship linking this item to all the times you've eaten it
  logs            FoodLogEntry[] 
}

// The Daily Diary (Your Food Tracking Sheet)
model FoodLogEntry {
  id               String   @id @default(uuid())
  dateLogged       DateTime @default(now())
  quantityConsumed Float
  itemType         String   

  // Manual Overrides (Nullable. If null, we calculate using FoodItem base values)
  manualServingSize Float?
  manualServingUnit String?        // e.g. "g", "oz", "cup
  manualCalories   Float?
  manualProtein    Float?
  manualFat        Float? 
  manualCarbs      Float? 
  manualCaffeine   Float? 

  // The Foreign Key linking back to the Master Dictionary
  foodItemId       String
  foodItem         FoodItem @relation(fields: [foodItemId], references: [id])
}